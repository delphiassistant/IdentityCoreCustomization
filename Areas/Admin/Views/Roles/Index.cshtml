@model IEnumerable<IdentityCoreCustomization.Models.Identity.ApplicationRole>

@{
    ViewData["Title"] = "گروه های کاربران";
    var returnUrl = Context.Request.GetEncodedPathAndQuery();
    var sortBy = ViewBag.SortBy as string ?? "name";
    var sortDir = ViewBag.SortDir as string ?? "asc";
    var q = ViewBag.Q as string;

    string SortLink(string col) => (sortBy == col && sortDir == "asc") ? "desc" : "asc";
    string SortIcon(string col) => sortBy == col ? (sortDir == "asc" ? " ▲" : " ▼") : "";
}

@section Styles {
    <style>
        .page-header {
            background: linear-gradient(135deg, #10b981 0%, #059669 100%);
            color: white;
            padding: 2rem;
            border-radius: 1rem;
            margin-bottom: 2rem;
            box-shadow: 0 8px 16px rgba(16, 185, 129, 0.3);
        }

        .page-header h1 {
            color: white;
            border: none;
            margin: 0;
            padding: 0;
        }

        .page-header h1::after {
            display: none;
        }

        .role-card {
            transition: all 0.3s ease;
            border: none;
            border-radius: 0.75rem;
            overflow: hidden;
        }

        .role-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 12px 24px rgba(0, 0, 0, 0.15) !important;
        }

        .role-icon {
            width: 60px;
            height: 60px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            transition: all 0.3s ease;
        }

        .role-card:hover .role-icon {
            transform: rotate(10deg) scale(1.1);
        }

        .table tbody tr {
            transition: all 0.2s ease;
        }

        .table-hover tbody tr:hover {
            background: linear-gradient(to left, rgba(16, 185, 129, 0.08), rgba(5, 150, 105, 0.05));
            transform: scale(1.005);
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
        }
    </style>
}

<div class="page-header">
    <h1 class="mb-0">
        <i class="fa-solid fa-user-tag"></i> @ViewData["Title"]
    </h1>
    <p class="mb-0 mt-2 opacity-75">مدیریت نقش‌ها و سطوح دسترسی</p>
</div>

<div class="mb-3 d-flex justify-content-between align-items-center gap-3 flex-wrap">
    <a asp-action="Create" class="btn btn-success btn-lg shadow">
        <i class="fa-solid fa-plus"></i> افزودن نقش جدید
    </a>
    <form method="get" asp-action="Index" class="d-flex gap-2" role="search">
        <input type="hidden" name="sortBy" value="@sortBy" />
        <input type="hidden" name="sortDir" value="@sortDir" />
        <input type="hidden" name="page" value="1" />
        <input type="text" name="q" value="@q" class="form-control" placeholder="جستجو نقش..." style="min-width:200px" />
        <button type="submit" class="btn btn-outline-primary">
            <i class="fa-solid fa-magnifying-glass"></i>
        </button>
        @if (!string.IsNullOrWhiteSpace(q))
        {
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="fa-solid fa-xmark"></i>
            </a>
        }
    </form>
    <span class="badge bg-info fs-6">
        <i class="fa-solid fa-list-check"></i> تعداد: @((int)(ViewBag.TotalCount ?? 0))
    </span>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-striped table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th style="width: 50px;">
                            <i class="fa-solid fa-hashtag"></i>
                        </th>
                        <th>
                            <a asp-action="Index" asp-route-q="@q" asp-route-sortBy="name" asp-route-sortDir="@SortLink("name")" asp-route-pageSize="@ViewBag.PageSize" class="text-white text-decoration-none">
                                <i class="fa-solid fa-tag"></i> نام نقش@SortIcon("name")
                            </a>
                        </th>
                        <th>
                            <i class="fa-solid fa-font"></i> نام نرمالیزشده
                        </th>
                        <th class="text-center" style="width: 150px;">
                            <i class="fa-solid fa-cog"></i> دستورات
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        var index = ((int)(ViewBag.Page ?? 1) - 1) * (int)(ViewBag.PageSize ?? 50) + 1;
                    }
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <div class="role-icon bg-success bg-opacity-10 text-success" style="width: 40px; height: 40px; font-size: 1rem;">
                                    <strong>@index</strong>
                                </div>
                            </td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <i class="fa-solid fa-user-tag text-success"></i>
                                    <strong class="fs-6 ms-2">@Html.DisplayFor(modelItem => item.Name)</strong>
                                </div>
                            </td>
                            <td>
                                <code class="bg-light px-3 py-2 rounded">@Html.DisplayFor(modelItem => item.NormalizedName)</code>
                            </td>
                            <td>
                                <div class="btn-group" role="group">
                                    <a asp-action="Details" asp-route-id="@item.Id" asp-route-returnUrl="@returnUrl"
                                       class="btn btn-info btn-sm" title="مشاهده جزئیات">
                                        <i class="fa-solid fa-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@item.Id" asp-route-returnUrl="@returnUrl"
                                       class="btn btn-primary btn-sm" title="ویرایش">
                                        <i class="fa-solid fa-pen-to-square"></i> ویرایش
                                    </a>
                                </div>
                            </td>
                        </tr>
                        index++;
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@await Html.PartialAsync("_Pagination")

@if (!Model.Any())
{
    <div class="alert alert-info text-center mt-4">
        <i class="fa-solid fa-info-circle fs-3 d-block mb-2"></i>
        <strong>هیچ نقشی تعریف نشده است.</strong>
        <p class="mb-0 mt-2">برای شروع، یک نقش جدید ایجاد کنید.</p>
    </div>
}