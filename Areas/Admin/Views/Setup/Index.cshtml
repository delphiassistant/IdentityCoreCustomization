@model IdentityCoreCustomization.Areas.Admin.Models.SetupViewModel
@{
    Layout = "~/Areas/Users/Views/Shared/_AuthLayout.cshtml";
    ViewData["Title"] = "راه‌اندازی اولیه سیستم";
}

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-header">
            <div class="icon">
                <i class="fa-solid fa-shield-halved"></i>
            </div>
            <h1>@ViewData["Title"]</h1>
        </div>

        <div class="auth-body">
            <div class="auth-alert auth-alert-info mb-4">
                <i class="fa-solid fa-circle-info"></i>
                <p class="mb-0">
                    هنوز هیچ مدیری در سیستم ثبت نشده است.
                    این حساب نقش <strong>مدیر ارشد (Admin)</strong> خواهد داشت و این مرحله تنها یک بار انجام می‌شود.
                </p>
            </div>

            @if (ViewData.ModelState.ErrorCount > 0)
            {
                <div class="auth-alert auth-alert-danger">
                    <i class="fa-solid fa-circle-exclamation"></i>
                    <div asp-validation-summary="ModelOnly" class="mb-0"></div>
                </div>
            }

            <form id="setup" method="post" asp-area="Admin" asp-controller="Setup" asp-action="Index" class="auth-form">
                <div class="mb-3">
                    <label asp-for="Username" class="form-label">
                        <i class="fa-solid fa-user text-primary"></i>
                        @Html.DisplayNameFor(m => m.Username)
                    </label>
                    <input asp-for="Username"
                           class="form-control"
                           autocomplete="username"
                           placeholder="نام کاربری منحصربه‌فرد"
                           autofocus />
                    <span asp-validation-for="Username" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label">
                        <i class="fa-solid fa-envelope text-info"></i>
                        @Html.DisplayNameFor(m => m.Email)
                    </label>
                    <input asp-for="Email"
                           class="form-control ltr"
                           dir="ltr"
                           autocomplete="email"
                           placeholder="example@domain.com (اختیاری)" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label">
                        <i class="fa-solid fa-lock text-success"></i>
                        @Html.DisplayNameFor(m => m.Password)
                    </label>
                    <div class="position-relative">
                        <input asp-for="Password"
                               class="form-control ltr"
                               id="passwordInput"
                               dir="ltr"
                               autocomplete="new-password"
                               placeholder="رمز عبور قوی انتخاب کنید" />
                        <button type="button" class="password-toggle" onclick="togglePassword('passwordInput', 'toggleIcon1')">
                            <i class="fa-solid fa-eye" id="toggleIcon1"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                    <div class="password-strength bg-secondary" id="passwordStrength"></div>

                    <div class="mt-3" id="requirements">
                        <div class="requirement-item" data-requirement="length">
                            <span class="requirement-icon">
                                <i class="fa-solid fa-check"></i>
                            </span>
                            <span>حداقل 6 کاراکتر</span>
                        </div>
                        <div class="requirement-item" data-requirement="uppercase">
                            <span class="requirement-icon">
                                <i class="fa-solid fa-check"></i>
                            </span>
                            <span>شامل حروف بزرگ (A-Z)</span>
                        </div>
                        <div class="requirement-item" data-requirement="lowercase">
                            <span class="requirement-icon">
                                <i class="fa-solid fa-check"></i>
                            </span>
                            <span>شامل حروف کوچک (a-z)</span>
                        </div>
                        <div class="requirement-item" data-requirement="number">
                            <span class="requirement-icon">
                                <i class="fa-solid fa-check"></i>
                            </span>
                            <span>شامل عدد (0-9)</span>
                        </div>
                    </div>
                </div>

                <div class="mb-4">
                    <label asp-for="ConfirmPassword" class="form-label">
                        <i class="fa-solid fa-check-double text-warning"></i>
                        @Html.DisplayNameFor(m => m.ConfirmPassword)
                    </label>
                    <div class="position-relative">
                        <input asp-for="ConfirmPassword"
                               class="form-control ltr"
                               id="confirmPasswordInput"
                               dir="ltr"
                               autocomplete="new-password"
                               placeholder="رمز عبور را مجدداً وارد کنید" />
                        <button type="button" class="password-toggle" onclick="togglePassword('confirmPasswordInput', 'toggleIcon2')">
                            <i class="fa-solid fa-eye" id="toggleIcon2"></i>
                        </button>
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>

                <button type="submit" class="auth-btn auth-btn-primary">
                    <i class="fa-solid fa-shield-halved"></i>
                    ایجاد حساب مدیر و ورود به سیستم
                </button>
            </form>
        </div>
    </div>

    <div class="back-to-home">
        <a href="/">
            <i class="fa-solid fa-home"></i>
            بازگشت به صفحه اصلی
        </a>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
