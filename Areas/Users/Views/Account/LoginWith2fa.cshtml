@model LoginWith2faModel
@{
    ViewData["Title"] = "احراز هویت دو مرحله‌ای";
    Layout = "~/Areas/Users/Views/Shared/_AuthLayout.cshtml";
}

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-header">
            <div class="icon">
                <i class="fa-solid fa-shield-halved"></i>
            </div>
            <h1>@ViewData["Title"]</h1>
        </div>

        <div class="auth-body">
            @if (ViewData.ModelState.ErrorCount > 0)
            {
                <div class="auth-alert auth-alert-danger">
                    <i class="fa-solid fa-circle-exclamation"></i>
                    <div asp-validation-summary="ModelOnly" class="mb-0"></div>
                </div>
            }

            <div class="auth-alert auth-alert-info mb-4">
                <i class="fa-solid fa-info-circle"></i>
                <p class="mb-0">
                    برنامه احراز هویت شما یک کد امنیتی ۶ رقمی ایجاد کرده است. کد را وارد کنید.
                </p>
            </div>

            <form method="post" class="auth-form">
                <input type="hidden" asp-for="ReturnUrl" />
                <input type="hidden" asp-for="RememberMe" />
                
                <div class="mb-3">
                    <label asp-for="TwoFactorCode" class="form-label">
                        <i class="fa-solid fa-key text-success"></i>
                        @Html.DisplayNameFor(m => m.TwoFactorCode)
                    </label>
                    <input asp-for="TwoFactorCode" class="form-control auth-code-input" 
                           autocomplete="off" 
                           maxlength="6"
                           autofocus />
                    <span asp-validation-for="TwoFactorCode" class="text-danger small"></span>
                    <small class="text-muted d-block mt-2">
                        <i class="fa-solid fa-mobile-screen-button"></i>
                        کد ۶ رقمی را از برنامه احراز هویت خود وارد کنید
                    </small>
                </div>
                
                <div class="form-check mb-4">
                    <input asp-for="RememberMachine" class="form-check-input" id="rememberMachine" />
                    <label asp-for="RememberMachine" class="form-check-label" for="rememberMachine">
                        @Html.DisplayNameFor(m => m.RememberMachine)
                    </label>
                    <small class="text-muted d-block mt-1">
                        در این دستگاه دیگر از شما کد نخواهد خواست
                    </small>
                </div>

                <button type="submit" class="auth-btn auth-btn-primary">
                    <i class="fa-solid fa-right-to-bracket fa-flip-horizontal"></i>
                    تأیید و ورود
                </button>

                <div class="auth-links">
                    <div class="auth-divider">
                        <span>برای دریافت کد مشکل دارید؟</span>
                    </div>
                    <a asp-action="LoginWithSms" asp-route-returnUrl="@Model.ReturnUrl" class="auth-link">
                        <i class="fa-solid fa-mobile-screen-button text-info"></i>
                        <span>ورود از طریق پیامک</span>
                    </a>
                    <a asp-action="LoginWithRecoveryCode" asp-route-returnUrl="@Model.ReturnUrl" class="auth-link auth-link-warning">
                        <i class="fa-solid fa-life-ring text-warning"></i>
                        <span>استفاده از کد بازیابی</span>
                    </a>
                    
                    <a asp-action="Login" class="auth-link">
                        <i class="fa-solid fa-arrow-left text-secondary"></i>
                        <span>بازگشت به صفحه ورود</span>
                    </a>
                </div>
            </form>
        </div>
    </div>

    <div class="back-to-home">
        <a href="/">
            <i class="fa-solid fa-home"></i>
            بازگشت به صفحه اصلی
        </a>
    </div>
</div>


