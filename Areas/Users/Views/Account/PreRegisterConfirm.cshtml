@model IdentityCoreCustomization.Models.Identity.UserPhoneTokenConfirmViewModel

@{
    ViewData["Title"] = "تأیید کد پیامکی";
    Layout = "~/Areas/Users/Views/Shared/_AuthLayout.cshtml";
}

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-header">
            <div class="icon">
                <i class="fa-solid fa-message-sms"></i>
            </div>
            <h1>@ViewData["Title"]</h1>
        </div>

        <div class="auth-body">
            @if (ViewData.ModelState.ErrorCount > 0)
            {
                <div class="auth-alert auth-alert-danger">
                    <i class="fa-solid fa-circle-exclamation"></i>
                    <div asp-validation-summary="ModelOnly" class="mb-0"></div>
                </div>
            }

            <div class="auth-alert auth-alert-info mb-4">
                <i class="fa-solid fa-info-circle"></i>
                <p class="mb-0">
                    <strong>مرحله دوم:</strong> کد تأیید ۶ رقمی که به شماره موبایل شما ارسال شد را وارد کنید.
                </p>
            </div>

            <form asp-action="PreRegisterConfirm" class="auth-form">
                <input type="hidden" asp-for="AuthenticationKey"/>
                
                <div class="mb-4">
                    <label asp-for="AuthenticationCode" class="form-label">
                        <i class="fa-solid fa-key text-success"></i>
                        @Html.DisplayNameFor(m => m.AuthenticationCode)
                    </label>
                    <input asp-for="AuthenticationCode" 
                           class="form-control auth-code-input" 
                           autocomplete="off"                            
                           maxlength="6"
                           autofocus />
                    <span asp-validation-for="AuthenticationCode" class="text-danger small"></span>
                    <small class="text-muted d-block mt-2">
                        <i class="fa-solid fa-mobile-screen-button"></i>
                        کد ۶ رقمی ارسال شده به موبایل خود را وارد کنید
                    </small>
                </div>

                <button type="submit" class="auth-btn auth-btn-primary">
                    <i class="fa-solid fa-check-circle"></i>
                    تأیید و ادامه
                </button>

                <div class="auth-links">
                    <div class="auth-divider">
                        <span>مشکل در دریافت کد؟</span>
                    </div>
                    
                    <a asp-action="PreRegister" class="auth-link auth-link-warning">
                        <i class="fa-solid fa-rotate text-warning"></i>
                        <span>ارسال مجدد کد</span>
                    </a>
                    
                    <a asp-action="Login" class="auth-link">
                        <i class="fa-solid fa-arrow-left text-secondary"></i>
                        <span>بازگشت به صفحه ورود</span>
                    </a>
                </div>
            </form>

            <div class="alert alert-info text-start mt-4 mb-0">
                <h6 class="fw-bold mb-2">
                    <i class="fa-solid fa-lightbulb"></i> نکات مهم
                </h6>
                <ul class="small mb-0">
                    <li>کد تأیید ممکن است چند دقیقه طول بکشد</li>
                    <li>اگر کد را دریافت نکردید، دوباره درخواست دهید</li>
                    <li>کد تأیید معتبر محدود است</li>
                </ul>
            </div>
        </div>
    </div>

    <div class="back-to-home">
        <a href="/">
            <i class="fa-solid fa-home"></i>
            بازگشت به صفحه اصلی
        </a>
    </div>
</div>


