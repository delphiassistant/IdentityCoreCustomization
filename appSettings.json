{
  "ConnectionStrings": {
    "DefaultConnection": "Encrypt=false;Server=localhost;Database=IdentityCoreCustomization;Trusted_Connection=True;MultipleActiveResultSets=true"
  },
  "GeneralConfig": {
        "SiteTitle": "سفارشی سازی آیدنتیتی",
        "ApplicationName": "IdentityCoreCustomization"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "theme": "Serilog.Sinks.SystemConsole.Themes.AnsiConsoleTheme::Code, Serilog.Sinks.Console",
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}{NewLine}{Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {SourceContext} {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "ParsGreen": {
    "SendFromNumber": "",
    "ApiToken": ""
  },
  "Identity": {
    "PreRegistrationEnabled": false,
    "Password": {
      "CheckPasswordWithHIBP": true,
      "RequireDigit": true,
      "RequiredLength": 6,
      "RequireNonAlphanumeric": false,
      "RequireUppercase": false,
      "RequireLowercase": false
    }
  },
  "AllowedHosts": "*",
  "Email": {
    "FromName": "",
    "FromEmail": "",
    "Smtp": {
      "Host": "",
      "Port": 25,
      "UserName": "",
      "Password": "",
      "SecureSocket": "None",
      "SkipCertValidation": false
    }
  }
}
